#!/usr/bin/bash

# tabber - A shell script for managing browser tabs
# Usage: ./tabber {store|find|delete|edit}
# TODO should be case insensitive, not working

TABBER_FILE="$HOME/.local/share/tabber.txt"

# Ensure the directory exists
mkdir -p "$(dirname "$TABBER_FILE")"

# Function to get page title from URL
get_page_title() {
    local url="$1"
    local title

    # Try to fetch the title using curl with better parsing
    title=$(curl -Ls --max-time 10 "$url" | pup --plain 'title text{}')

    # If no title found or empty, try alternative method
    if [[ -z "$title" ]]; then
        title=$(curl -s -L --max-time 10 "$url" | grep -oP '(?<=<title>)[^<]+' | head -n1 | sed 's/&amp;/\&/g; s/&lt;/</g; s/&gt;/>/g; s/&quot;/"/g; s/&#39;/'"'"'/g' | xargs)
    fi

    # If still no title found or empty, use a default
    if [[ -z "$title" ]]; then
        title="Untitled"
    fi

    title=$(echo "$title" | tr '\n\t' ' ' | tr -s ' ' | xargs)

    echo "$title"
}

# Function to store a new tab
store_tab() {
    # Get URL from clipboard
    local url
    url=$(wl-paste)

    if [[ -z "$url" ]]; then
        echo "Error: No URL found in clipboard"
        notify-send "Tabber Error" "No URL found in clipboard"
        exit 1
    fi

    # Validate URL format (basic check)
    if [[ ! "$url" =~ ^https?:// ]]; then
        echo "Error: Invalid URL format. Must start with http:// or https://"
        notify-send "Tabber Error" "Invalid URL format: $url"
        exit 1
    fi

    # Check for duplicate URL (skip deleted entries)
    if [[ -f "$TABBER_FILE" ]]; then
        local existing
        existing=$(grep -F "$url" "$TABBER_FILE" | grep -v '^#' | head -n1)
        if [[ -n "$existing" ]]; then
            local existing_title existing_date existing_tags
            existing_title=$(echo "$existing" | cut -f2)
            existing_date=$(echo "$existing" | cut -f3)
            existing_tags=$(echo "$existing" | cut -f4)
            echo "Error: URL already stored: $existing_title ($existing_date) [$existing_tags]"
            notify-send "Tabber" "Duplicate URL\n$existing_title\n$existing_date · $existing_tags" --icon=dialog-warning
            exit 1
        fi
    fi

    # Get todo/archive choice (now stored as a tag)
    local type
    type=$(echo -e "todo\narchive" | rofi --case-smart -dmenu -p " Type:")

    if [[ -z "$type" ]]; then
        echo "Operation cancelled"
        notify-send "Tabber" "Operation cancelled"
        exit 0
    fi

    # Get optional tags
    local tags
    tags=$(rofi -dmenu -p " Tags (comma separated, optional):")

    # Merge type into tags (type is now a tag)
    if [[ -z "$tags" ]]; then
        tags="$type"
    else
        tags="$tags,$type"
    fi

    # Get current date
    local date
    date=$(date '+%Y-%m-%d')

    # Get page title (last, so it doesn't block rofi prompts)
    echo "Fetching page title..."
    local title
    title=$(get_page_title "$url")

    # New file format: URL<TAB>TITLE<TAB>DATE<TAB>TAGS
    local entry="${url}	${title}	${date}	${tags}"

    # Append to file
    echo "$entry" >> "$TABBER_FILE"

    echo "Tab stored: $title"
    notify-send "Tabber" "Tab stored: $title" --icon=browser
}

# Helper: check if a comma-separated tag list contains a specific tag (case-insensitive)
tags_contain() {
    local tags="$1"
    local want="$2"
    grep -qiE '(^|[[:space:]]*,[[:space:]]*)'"$want"'([[:space:]]*,[[:space:]]*|$)' <<<"$tags"
}

# Function to find and copy a tab
find_tab() {
    local filter_type="$1"  # "todo", "archive", "both", or empty for menu

    if [[ ! -f "$TABBER_FILE" ]]; then
        echo "No tabs stored yet"
        exit 1
    fi

    # If no filter specified, show menu to choose
    if [[ -z "$filter_type" ]]; then
        filter_type=$(echo -e "todo\nboth\narchive" | rofi -dmenu -p " Show which tabs:")

        if [[ -z "$filter_type" ]]; then
            echo "No selection made"
            exit 0
        fi
    fi

    # Read non-deleted entries and format for rofi
    local entries=()
    while IFS=$'\t' read -r url title date tags; do
        # Skip deleted entries (starting with #)
        if [[ "$url" =~ ^# ]]; then
            continue
        fi

        # Apply filter if not "both" (filter is now tag-based)
        if [[ "$filter_type" != "both" ]]; then
            if ! tags_contain "$tags" "$filter_type"; then
                continue
            fi
        fi

        # Format: "title | url | date | tags"
        local display_tags="${tags:-"(no tags)"}"
        entries+=("$title | $url | $date | $display_tags")
    done < "$TABBER_FILE"

    if [[ ${#entries[@]} -eq 0 ]]; then
        if [[ "$filter_type" == "both" ]]; then
            echo "No active tabs found"
        else
            echo "No tabs found tagged '$filter_type'"
        fi
        exit 1
    fi

    # Show in rofi with appropriate prompt
    local prompt="Select tab:"
    case "$filter_type" in
        "todo") prompt="Select todo tab:" ;;
        "archive") prompt="Select archive tab:" ;;
        "both") prompt="Select tab:" ;;
    esac

    local selected
    selected=$(printf '%s\n' "${entries[@]}" | tac | rofi --case-smart -dmenu -p " $prompt")

    if [[ -z "$selected" ]]; then
        echo "No selection made"
        exit 0
    fi

    # Extract URL from selection (it is the second field after the first |)
    local selected_url
    selected_url=$(echo "$selected" | cut -d'|' -f2 | xargs)

    # Copy to clipboard
    echo -n "$selected_url" | wl-copy
    echo "URL copied to clipboard: $selected_url"
}

# Function to edit an existing tab
edit_tab() {
    if [[ ! -f "$TABBER_FILE" ]]; then
        echo "No tabs stored yet"
        exit 1
    fi

    # Read non-deleted entries and format for rofi
    local entries=()
    local line_numbers=()
    local line_num=0

    while IFS=$'\t' read -r url title date tags; do
        ((line_num++))
        if [[ "$url" =~ ^# ]]; then
            continue
        fi
        local display_tags="${tags:-"(no tags)"}"
        entries+=("$title | $url | $date | $display_tags")
        line_numbers+=("$line_num")
    done < "$TABBER_FILE"

    if [[ ${#entries[@]} -eq 0 ]]; then
        echo "No active tabs found"
        exit 1
    fi

    # Pick a tab to edit
    local selected
    selected=$(printf '%s\n' "${entries[@]}" | tac | rofi --case-smart -dmenu -p " Select tab to edit:")

    if [[ -z "$selected" ]]; then
        echo "No selection made"
        exit 0
    fi

    # Find the index and line number
    local selected_index=-1
    for i in "${!entries[@]}"; do
        if [[ "${entries[$i]}" == "$selected" ]]; then
            selected_index=$i
            break
        fi
    done

    if [[ $selected_index -eq -1 ]]; then
        echo "Error: Could not find selected entry"
        exit 1
    fi

    local target_line=${line_numbers[$selected_index]}

    # Read current values directly from the file using the line number
    local raw_line
    raw_line=$(sed -n "${target_line}p" "$TABBER_FILE")

    local current_url current_title current_date current_tags
    current_url=$(echo "$raw_line" | cut -f1)
    current_title=$(echo "$raw_line" | cut -f2)
    current_date=$(echo "$raw_line" | cut -f3)
    current_tags=$(echo "$raw_line" | cut -f4)

    # Edit URL (with duplicate check, excluding current line)
    local new_url
    new_url=$(rofi -dmenu -p " URL:" -filter "$current_url" <<< "")
    if [[ -z "$new_url" ]]; then
        echo "Operation cancelled"
        exit 0
    fi
    if [[ ! "$new_url" =~ ^https?:// ]]; then
        echo "Error: Invalid URL format"
        notify-send "Tabber Error" "Invalid URL format: $new_url"
        exit 1
    fi
    # Duplicate check — skip if URL is unchanged
    if [[ "$new_url" != "$current_url" ]]; then
        local dupe
        dupe=$(grep -F "$new_url" "$TABBER_FILE" | grep -v '^#' | head -n1)
        if [[ -n "$dupe" ]]; then
            local dupe_title dupe_date dupe_tags
            dupe_title=$(echo "$dupe" | cut -f2)
            dupe_date=$(echo "$dupe" | cut -f3)
            dupe_tags=$(echo "$dupe" | cut -f4)
            echo "Error: URL already stored: $dupe_title ($dupe_date) [$dupe_tags]"
            notify-send "Tabber" "Duplicate URL\n$dupe_title\n$dupe_date · $dupe_tags" --icon=dialog-warning
            exit 1
        fi
    fi

    # Edit title
    local new_title
    new_title=$(rofi -dmenu -p " Title:" -filter "$current_title" <<< "")
    if [[ -z "$new_title" ]]; then
        echo "Operation cancelled"
        exit 0
    fi

    # Edit tags
    local new_tags
    new_tags=$(rofi -dmenu -p " Tags:" -filter "$current_tags" <<< "")
    if [[ -z "$new_tags" ]]; then
        echo "Operation cancelled"
        exit 0
    fi

    # Write updated entry back to file
    local new_entry="${new_url}	${new_title}	${current_date}	${new_tags}"
    local temp_file
    temp_file=$(mktemp)
    local current_line=0

    while IFS= read -r line; do
        ((current_line++))
        if [[ $current_line -eq $target_line ]]; then
            echo "$new_entry" >> "$temp_file"
        else
            echo "$line" >> "$temp_file"
        fi
    done < "$TABBER_FILE"

    mv "$temp_file" "$TABBER_FILE"

    echo "Tab updated: $new_title"
    notify-send "Tabber" "Tab updated: $new_title" --icon=browser
}

# Function to delete (mark as deleted) a tab
delete_tab() {
    if [[ ! -f "$TABBER_FILE" ]]; then
        echo "No tabs stored yet"
        exit 1
    fi

    # Read non-deleted entries and format for rofi
    local entries=()
    local line_numbers=()
    local line_num=0

    while IFS=$'\t' read -r url title date tags; do
        ((line_num++))

        # Skip already deleted entries
        if [[ "$url" =~ ^# ]]; then
            continue
        fi

        # Format: "title | url | date | tags"
        local display_tags="${tags:-"(no tags)"}"
        entries+=("$title | $url | $date | $display_tags")
        line_numbers+=("$line_num")
    done < "$TABBER_FILE"

    if [[ ${#entries[@]} -eq 0 ]]; then
        echo "No active tabs found"
        exit 1
    fi

    # Show in rofi
    local selected
    selected=$(printf '%s\n' "${entries[@]}" | rofi -dmenu -p " Select tab to delete:")

    if [[ -z "$selected" ]]; then
        echo "No selection made"
        exit 0
    fi

    # Find which entry was selected
    local selected_index=-1
    for i in "${!entries[@]}"; do
        if [[ "${entries[$i]}" == "$selected" ]]; then
            selected_index=$i
            break
        fi
    done

    if [[ $selected_index -eq -1 ]]; then
        echo "Error: Could not find selected entry"
        exit 1
    fi

    # Get the line number to modify
    local target_line=${line_numbers[$selected_index]}

    # Create a temporary file and mark the entry as deleted
    local temp_file
    temp_file=$(mktemp)
    local current_line=0

    while IFS= read -r line; do
        ((current_line++))
        if [[ $current_line -eq $target_line ]]; then
            # Mark as deleted by adding # at the beginning
            echo "#$line" >> "$temp_file"
        else
            echo "$line" >> "$temp_file"
        fi
    done < "$TABBER_FILE"

    # Replace the original file
    mv "$temp_file" "$TABBER_FILE"

    echo "Tab marked as deleted"
}

# Function to prune deleted entries
prune_tabs() {
    if [[ ! -f "$TABBER_FILE" ]]; then
        echo "No tabs stored yet"
        exit 1
    fi

    # Count lines before pruning
    local total_lines
    total_lines=$(wc -l < "$TABBER_FILE")

    # Create a temporary file with only non-deleted entries
    local temp_file
    temp_file=$(mktemp)

    while IFS= read -r line; do
        # Only keep lines that don't start with #
        if [[ ! "$line" =~ ^# ]]; then
            echo "$line" >> "$temp_file"
        fi
    done < "$TABBER_FILE"

    # Count lines after pruning
    local remaining_lines
    remaining_lines=$(wc -l < "$temp_file")
    local deleted_count=$((total_lines - remaining_lines))

    # Replace the original file
    mv "$temp_file" "$TABBER_FILE"

    echo "Pruned $deleted_count deleted entries"
    echo "Remaining entries: $remaining_lines"
    notify-send "Tabber" "Pruned $deleted_count deleted entries" --icon=edit-delete
}

# Function to show help
show_help() {
    echo "tabber - Tab management script"
    echo
    echo "Usage:"
    echo "  ./tabber store         - Store URL from clipboard with metadata"
    echo "  ./tabber find          - Show menu to choose tag filter, then find and copy URL"
    echo "  ./tabber find todo     - Find and copy from entries tagged todo"
    echo "  ./tabber find archive  - Find and copy from entries tagged archive"
    echo "  ./tabber find both     - Find and copy from all tabs"
    echo "  ./tabber edit          - Edit an existing tab's URL, title, or tags"
    echo "  ./tabber delete        - Mark a tab as deleted"
    echo "  ./tabber prune         - Remove all deleted entries from storage"
    echo "  ./tabber help          - Show this help message"
    echo
    echo "File format: URL<tab>TITLE<tab>DATE<tab>TAGS"
    echo "Storage location: $TABBER_FILE"
}

# Main script logic
case "$1" in
    "store")
        store_tab
        ;;
    "find")
        if [[ "$2" == "todo" || "$2" == "archive" || "$2" == "both" ]]; then
            find_tab "$2"
        else
            find_tab
        fi
        ;;
    "edit")
        edit_tab
        ;;
    "delete")
        delete_tab
        ;;
    "prune")
        prune_tabs
        ;;
    "help"|"--help"|"-h")
        show_help
        ;;
    "")
        echo "Error: No command specified"
        show_help
        exit 1
        ;;
    *)
        echo "Error: Unknown command '$1'"
        show_help
        exit 1
        ;;
esac
