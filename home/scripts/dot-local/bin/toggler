#!/usr/bin/env bash
case $1 in
cmus)
    # pgrep -x cmus || $TERMINAL -a cmus -e cmus
    pgrep -x cmus || $TERMINAL --class cmus -e cmus
    hyprctl dispatch focuswindow "^(cmus)$"
    ;;
# sway "[app_id=cmus] scratchpad show; [app_id=cmus] move position center";;
discord)
    pgrep -x discord || setsid discord &
    sway "workspace 9; [class=discord] focus"
    ;;
discord-brave)
    hyprctl clients -j |
        jq -e '.[] | select(.class == "brave-magkoliahgffibhgfkmoealggombgknl-Default")' ||
        gtk-launch brave-magkoliahgffibhgfkmoealggombgknl-Default
    hyprctl dispatch togglespecialworkspace discord
    ;;
display)
    rofi -dmenu -theme-str '
        entry {enabled: false;}
        listview {lines: 0;}
        window {height: 5%; width: 10%;}
    ' -p " Confirm?"
    ret=$?

    if [ $ret -eq 0 ]; then
        hyprctl keyword monitor "eDP-1, disable"
    elif [ $ret -eq 1 ]; then
        hyprctl keyword monitor "eDP-1, enable"
    fi
    ;;
espanso)
    pgrep -x espanso && (
        espanso stop
        notify-send -t 1000 "Espanso stopped."
    ) ||
        setsid espanso daemon &
    ;;

nixpkgs-float)
    hyprctl clients -j | jq 'any(.[]; .initialTitle == "https://search.nixos.org/packages?channel=unstable&include_home_manager_options=1&include_modular_service_options=1&include_nixos_options=1 - qutebrowser")' ||
        xdg-launch qutebrowser 'https://search.nixos.org/packages?channel=unstable&include_home_manager_options=1&include_modular_service_options=1&include_nixos_options=1'
    hyprctl dispatch togglespecialworkspace nixpkgs-float
    ;;

gmail)
    hyprctl clients -j | jq -e '.[] | \
        select(.class == "brave-fmgjjmmmlfnkbppncabfkddbjimcfncm-Default")' ||
        gtk-launch brave-fmgjjmmmlfnkbppncabfkddbjimcfncm-Default
    hyprctl dispatch togglespecialworkspace gmail
    ;;
inhibit-lid)
    pgrep -x sleep && {
        killall sleep &
        notify-send 'Stop inhibiting sleep on lid-close.'
    } ||
        {
            systemd-inhibit --what=handle-lid-switch sleep 1h &
            notify-send 'Inhibit sleep on lid-close.'
        }
    ;;
mailspring)
    pgrep -x mailspring || setsid mailspring &
    sway "workspace 9; [class=Mailspring] focus"
    ;;
megasync)
    QT_QPA_PLATFORM='xcb'
    pgrep -x "megasync" && killall megasync || setsid megasync &
    ;;
music)
    # pgrep -x "spotify|cmus|spotifyd" && playerctl --player=spotify,cmus,spotifyd play-pause;;
    playerctl --player=spotify,cmus,spotifyd,%any play-pause
    ;;
music-player)
    sway "[instance=spotify] scratchpad show; [instance=spotify] move \
        position center; [app_id=cmus] scratchpad show; [app_id=cmus] move \
        position center"
    ;;
neomutt)
    # pgrep -x cmus || $TERMINAL -a cmus -e cmus
    pgrep -x neomutt || $TERMINAL --class neomutt -e neomutt
    hyprctl dispatch focuswindow "^(neomutt)$"
    ;;
    # sway "[app_id=cmus] scratchpad show; [app_id=cmus] move position center";;
nerd-dictation)
    if pgrep -f "nerd-dictation begin"; then
        notify-send "dictation end"
        nerd-dictation end
    else
        notify-send "dictation start"
        nerd-dictation begin --simulate-input-tool=YDOTOOL
    fi
    ;;
nextcloud)
    pgrep -x "nextcloud" && killall nextcloud || setsid nextcloud &
    ;;
nm-applet)
    pgrep -x "nm-applet" && killall nm-applet || setsid nm-applet &
    ;;
notes)
    # pgrep -x emacs || $TERMINAL --class notes -e emacs -nw ~/documents/org/main.org
    pgrep -x emacs || emacs --name notes ~/documents/org/main.org
    hyprctl dispatch focuswindow "^(notes)$"
    ;;
    # sway "[app_id=cmus] scratchpad show; [app_id=cmus] move position center";;
instagram)
    hyprctl clients -j |
        jq -e '.[] | select(.class == "brave-www.instagram.com__direct_inbox_-Default")' ||
        xdg-launch brave --app='https://www.instagram.com/direct/inbox/' &
    hyprctl dispatch togglespecialworkspace instagram
    ;;
gammastep)
    pgrep -x "gammastep" && {
        killall gammastep
        notify-send -t 1000 "Killing gammastep"
    } ||
        {
            notify-send -t 1000 "Starting Gammastep."
            setsid gammastep
        }
    ;;
spotifyd)
    pgrep -x spotifyd && (
        notify-send -t 1000 "Killing spotifyd."
        killall spotifyd
    ) ||
        (
            notify-send -t 1000 "Starting spotifyd."
            setsid xdg-launch spotifyd &
        )
    ;;
spotify-tui)
    pgrep -x "spotifyd" || spotifyd &
    pgrep -x spt || ($TERMINAL -a spt -e spt && sleep .1)
    sway "[app_id=spt] scratchpad show; [app_id=spt] move position center"
    ;;
ticktick)
    pgrep -x ticktick || gtk-launch ticktick
    # sway "workspace 9; [class=Signal] focus";;
    hyprctl dispatch focuswindow "^(ticktick)$"
    ;;
ticktick-brave)
    hyprctl clients -j | \ 
    jq -e '.[] | select(.class == "brave-cfammbeebmjdpoppachopcohfchgjapd-Default")' ||
        gtk-launch brave-cfammbeebmjdpoppachopcohfchgjapd-Default
    hyprctl dispatch togglespecialworkspace ticktick
    ;;
habitica-brave)
    hyprctl clients -j |
        jq -e '.[] | select(.class == "brave-pdigihnmoiplkhocekidmdcmhchhdpjo-Default")' ||
        gtk-launch brave-pdigihnmoiplkhocekidmdcmhchhdpjo-Default
    hyprctl dispatch togglespecialworkspace habitica
    ;;
tmux) ;;
torbrowser)
    wmctrl -l | grep -q "Tor Browser" || setsid torbrowser-launcher &
    sway "workspace 7"
    ;;
whatsapp)
    hyprctl clients -j |
        jq -e '.[] | select(.class == "brave-hnpfjngllnobngcgfapefoaidbinmjnm-Default")' ||
        gtk-launch brave-hnpfjngllnobngcgfapefoaidbinmjnm-Default
    hyprctl dispatch togglespecialworkspace whatsapp
    ;;
*)
    echo "Invalid argument." >&2
    exit 1
    ;;
esac
